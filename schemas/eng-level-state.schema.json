{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecForge Eng Level State",
  "type": "object",
  "required": [
    "version",
    "initiative",
    "state"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "initiative": {
      "type": "string"
    },
    "state": {
      "enum": [
        "NO_CONTEXT",
        "UPSTREAM_INTAKE",
        "UPSTREAM_APPROVAL_REQUIRED",
        "RETURN_TO_PRODUCT_PLAN",
        "PLAN_REQUIRED",
        "PLAN_APPROVED",
        "WAITING_FOR_IMPLEMENTATION",
        "IMPLEMENTATION_IN_PROGRESS",
        "REVIEW_READY",
        "RETURN_TO_IMPLEMENTATION",
        "RETURN_TO_PLAN",
        "BLOCKED",
        "REVIEW_PASSED",
        "SHIP_READY"
      ]
    },
    "upstream_source": {
      "type": "string"
    },
    "upstream_approval_status": {
      "enum": [
        "PENDING",
        "APPROVED",
        "REJECTED",
        "REOPENED"
      ]
    },
    "upstream_approved_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "upstream_approved_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "implementation_head": {
      "type": [
        "string",
        "null"
      ]
    },
    "plan_status": {
      "enum": [
        null,
        "APPROVED",
        "APPROVED WITH CONDITIONS",
        "REVISE",
        "REJECTED",
        "UNVERIFIABLE"
      ]
    },
    "required_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "base_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "base_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "routed_roles": {
      "type": "array",
      "items": {
        "enum": [
          "architect",
          "manager",
          "staff-engineer",
          "backend-engineer",
          "platform-engineer"
        ]
      }
    },
    "temperament": {
      "enum": [
        null,
        "pragmatist",
        "purist"
      ]
    },
    "adversarial_pair": {
      "type": "boolean"
    },
    "stop_after": {
      "enum": [
        null,
        "product",
        "plan",
        "implement",
        "review",
        "qa"
      ]
    },
    "post_hoc_review": {
      "type": "boolean"
    },
    "final_decision": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "SHIP",
        "SHIP WITH REQUIRED FIXES",
        "SHIP WITH REQUIRED FIXES (UNGATED)",
        "RETURN TO IMPLEMENTATION",
        "RETURN TO PLAN",
        "BLOCK"
      ]
    },
    "open_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
